#include <stdio.h>
#include <kipr/wombat.h>
#include <stdlib.h>

// CONFIG
#define LEFT_SENSOR_PORT   1   // analog
#define RIGHT_SENSOR_PORT  0   // analog

#define LEFT_MOTOR         3
#define RIGHT_MOTOR        1

// Wenn die Sensoren auf Schwarz KLEINER messen, BLACK_IS_LOW = 1, sonst 0.
#define BLACK_IS_LOW       0

// Schwellwert Weiß/Schwarz (tunen!)
#define BLACK_T            30

// Geschwindigkeiten (tunen für euren Bot/Akku)
#define FAST_FWD           80
#define HARD_TURN          80
#define HARD_TURN_BACK     60

// Loop-Timing
#define DT_MS              30

// ====== 8er-Synchronisation ======
// Rolle dieses Roboters: 1 = Vorrang, 0 = Nachrang
#define PRIORITY_ROLE      0

// Wartezeit des Nachrang-Bots, nachdem der Vorrang-Bot losfährt (tunen!)
#define WAIT_AFTER_FIRST_MS  5000

// Staging-Punkte: direkt VOR den Seitenwechsel-Kurven
#define WAIT_CORNER_A      3   // erster Treffpunkt
#define WAIT_CORNER_B      7   // zweiter Treffpunkt (gegenüberliegend)

// ====== Platzhalter-Signalisierung ======
// Hier später echte Kommunikation/Erkennung einbauen (GPIO, IR, Funk, etc.)
static inline void signal_i_am_here(void) {
    // TODO: z.B. set_digital(PORT, 1); oder LED blinken
    msleep(50);
}

static inline int partner_has_arrived(void) {
    // TODO: z.B. digitalRead von Partner-Signal oder Sensor-Trigger
    // Für Tests: sofort "true"
    return 1;
}

// ====== Hilfsfunktionen ======
static inline int is_black(int v) {
    return BLACK_IS_LOW ? (v < BLACK_T) : (v > BLACK_T);
}

static inline void drive(int left, int right) {
    if (left  > 500) left  = 500;  
    if (left  < -500) left  = -500;
    if (right > 500) right = 500;  
    if (right < -500) right = -500;
    motor_power(LEFT_MOTOR, left);
    motor_power(RIGHT_MOTOR, right);
}

// Drehungen behalten ihre internen Werte bei
static void turnRight90(void) {
    drive(0,0); msleep(100);
    int FRONT_MS = 300, FRONT_PWR = 60;
    drive(FRONT_PWR, FRONT_PWR); msleep(FRONT_MS);

    drive(0,0); msleep(100);
    int SPIN = 80;
    drive(+SPIN, -SPIN); msleep(700);

    drive(0,0); msleep(100);
    drive(FRONT_PWR, FRONT_PWR); msleep(FRONT_MS);
}

static void turnLeft90(void) {
    drive(0,0); msleep(100);
    int FRONT_MS = 300, FRONT_PWR = 60;
    drive(FRONT_PWR, FRONT_PWR); msleep(FRONT_MS);

    drive(0,0);
    int SPIN = 80;
    drive(-SPIN, +SPIN); msleep(700);

    drive(0,0); msleep(100);
    drive(FRONT_PWR, FRONT_PWR); msleep(FRONT_MS);
}

static void turnRight180(void) {
    drive(0,0);
    int BACK_MS = 1500, BACK_PWR = 60;
    drive(-BACK_PWR, -BACK_PWR); msleep(BACK_MS);

    drive(0,0); msleep(100);
    int SPIN = 80;
    drive(+SPIN, -SPIN); msleep(1400);
}

// ====== Staging-Protokoll ======
static void staging_wait_protocol(void) {
    // Beide Roboter stehen an der Staging-Kurve, melden Ankunft und warten,
    // bis der Partner ebenfalls da ist.
    drive(0,0);
    signal_i_am_here();
    msleep(150); // Stabilisierung

    while (!partner_has_arrived()) {
        msleep(20);
    }

    // Vorrang fährt sofort los; Nachrang wartet zusätzliche Zeit
    if (PRIORITY_ROLE == 0) {
        msleep(WAIT_AFTER_FIRST_MS);
    }
    // Danach kehrt der Aufrufer zurück und führt die eigentliche Kurve aus.
}

// ====== Linienfolger mit 8er-Logik & alternierendem Staging ======
void followLine(int duration_ms) {
    int elapsed = 0;
    int currentCorner = 0;      // 0..7, danach Reset
    int staged_this_cycle = 0;  // pro 8er-Zyklus max. einmal stagen
    static int next_wait_corner = WAIT_CORNER_A; // alterniert zwischen A und B

    while (elapsed < duration_ms) {
        int L = analog(LEFT_SENSOR_PORT);
        int R = analog(RIGHT_SENSOR_PORT);

        int L_black = is_black(L);
        int R_black = is_black(R);

        if (!L_black && !R_black) {
            drive(FAST_FWD, FAST_FWD);

        } else if (L_black && !R_black) {
            drive(HARD_TURN_BACK, +HARD_TURN);

        } else if (R_black && !L_black) {
            drive(+HARD_TURN, HARD_TURN_BACK);

        } else {
            // beide schwarz -> Ecke erkannt
            drive(0,0);

            // === Alternierendes Staging an 3 bzw. 7 ===
            if (!staged_this_cycle && currentCorner == next_wait_corner) {
                staging_wait_protocol();
                staged_this_cycle = 1;
                // Nächsten Treffpunkt vormerken
                next_wait_corner = (next_wait_corner == WAIT_CORNER_A) ? WAIT_CORNER_B : WAIT_CORNER_A;
            }

            // Kurve fahren (erste 4: links, zweite 4: rechts)
            if (currentCorner < 4) {
                turnLeft90();
                currentCorner++;
            } else {
                turnRight90();
                currentCorner++;
            }

            if (currentCorner == 8) {
                currentCorner = 0;
                staged_this_cycle = 0; // neuen 8er starten (Treffpunkt bleibt alterniert)
            }

            drive(0,0); msleep(30);
            drive(FAST_FWD, FAST_FWD);
        }

        msleep(DT_MS);
        elapsed += DT_MS;
    }
    ao();
}

int main(void) {
    printf("2-sensor line follower with alternating staging at corners 3 & 7...\n");
    followLine(500000); // ~500s
    msleep(200);
    ao();
    return 0;
}
