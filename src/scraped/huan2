#include <stdio.h>
#include <kipr/wombat.h>
#include <stdlib.h>
#include <string.h>
#include <unistd.h>
#include <errno.h>
#include <arpa/inet.h>
#include <netinet/in.h>
#include <sys/socket.h>
#include <fcntl.h>

// ====== CONFIG ======
#define LEFT_SENSOR_PORT   1   // analog
#define RIGHT_SENSOR_PORT  0   // analog

#define LEFT_MOTOR         3
#define RIGHT_MOTOR        1

// Wenn die Sensoren auf Schwarz KLEINER messen, BLACK_IS_LOW = 1, sonst 0.
#define BLACK_IS_LOW       0

// Schwellwert Weiß/Schwarz (tunen!)
#define BLACK_T            190

// Geschwindigkeiten (tunen für euren Bot/Akku)
#define FAST_FWD           100
#define HARD_TURN          80
#define HARD_TURN_BACK     50

// Loop-Timing
#define DT_MS              10

// ====== 8er-Synchronisation ======
// Rolle dieses Roboters: 1 = Vorrang, 0 = Nachrang
#define PRIORITY_ROLE         0
// Wartezeit des Nachrang-Bots, nachdem der Vorrang-Bot losfährt (tunen!)
#define WAIT_AFTER_FIRST_MS   5000
// Staging-Punkte: direkt VOR den Seitenwechsel-Kurven
#define WAIT_CORNER_A         2
#define WAIT_CORNER_B         6

// ====== TCP-KOMM (Server/Client per Define wählen) ======
#define COMM_IS_SERVER   0                // 1 = dieser Bot ist Server, 0 = Client
#define COMM_SERVER_IP   "10.200.0.70"     // nur vom Client genutzt
#define COMM_PORT        500
#define COMM_BUF_SZ      1024

static int   comm_fd = -1;
static int   comm_connected = 0;
static int   partner_here_flag = 0;

// kleine Helper
static void set_nonblocking(int fd){
    int fl = fcntl(fd, F_GETFL, 0);
    if (fl >= 0) fcntl(fd, F_SETFL, fl | O_NONBLOCK);
}

static int comm_init(void){
    if (comm_connected) return 1;

#if COMM_IS_SERVER
    int srv = socket(AF_INET, SOCK_STREAM, 0);
    if (srv < 0){ perror("socket"); return 0; }

    int yes = 1;
    setsockopt(srv, SOL_SOCKET, SO_REUSEADDR, &yes, sizeof(yes));

    struct sockaddr_in addr; memset(&addr, 0, sizeof(addr));
    addr.sin_family      = AF_INET;
    addr.sin_addr.s_addr = htonl(INADDR_ANY);
    addr.sin_port        = htons(COMM_PORT);

    if (bind(srv, (struct sockaddr*)&addr, sizeof(addr)) < 0){
        perror("bind"); close(srv); return 0;
    }
    if (listen(srv, 1) < 0){
        perror("listen"); close(srv); return 0;
    }

    // Einmal annehmen (blockierend beim Start ist okay)
    struct sockaddr_in cli; socklen_t cl = sizeof(cli);
    int cfd = accept(srv, (struct sockaddr*)&cli, &cl);
    if (cfd < 0){ perror("accept"); close(srv); return 0; }

    // Server-Listen-Socket kann zu, wir behalten nur die Verbindung
    close(srv);
    set_nonblocking(cfd);
    comm_fd = cfd;
    comm_connected = 1;
#else
    int fd = socket(AF_INET, SOCK_STREAM, 0);
    if (fd < 0){ perror("socket"); return 0; }

    struct sockaddr_in srv; memset(&srv, 0, sizeof(srv));
    srv.sin_family = AF_INET;
    srv.sin_port   = htons(COMM_PORT);
    if (inet_pton(AF_INET, COMM_SERVER_IP, &srv.sin_addr) != 1){
        fprintf(stderr, "Invalid COMM_SERVER_IP: %s\n", COMM_SERVER_IP);
        close(fd);
        return 0;
    }

    // Beim Start blockierend verbinden – robust, einfach
    if (connect(fd, (struct sockaddr*)&srv, sizeof(srv)) < 0){
        perror("connect");
        close(fd);
        return 0;
    }
    set_nonblocking(fd);
    comm_fd = fd;
    comm_connected = 1;
#endif
    return 1;
}

static void comm_close(void){
    if (comm_fd >= 0) close(comm_fd);
    comm_fd = -1;
    comm_connected = 0;
}

// ====== Hilfsfunktionen ======
static inline int is_black(int v) {
    return BLACK_IS_LOW ? (v < BLACK_T) : (v > BLACK_T);
}

static inline void drive(int left, int right) {
    if (left  > 500) left  = 500;  
    if (left  < -500) left  = -500;
    if (right > 500) right = 500;  
    if (right < -500) right = -500;
    motor_power(LEFT_MOTOR, left);
    motor_power(RIGHT_MOTOR, right);
}

// Drehungen behalten ihre internen Werte bei
static void turnRight90(void) {
    drive(0,0); msleep(100);
    int FRONT_MS = 300, FRONT_PWR = 60;
    drive(FRONT_PWR, FRONT_PWR); msleep(FRONT_MS);

    drive(0,0); msleep(100);
    int SPIN = 80;
    drive(+SPIN, -SPIN); msleep(700);

    drive(0,0); msleep(100);
    drive(FRONT_PWR, FRONT_PWR); msleep(FRONT_MS);
}

static void turnLeft90(void) {
    drive(0,0); msleep(100);
    int FRONT_MS = 300, FRONT_PWR = 60;
    drive(FRONT_PWR, FRONT_PWR); msleep(FRONT_MS);

    drive(0,0);
    int SPIN = 80;
    drive(-SPIN, +SPIN); msleep(700);

    drive(0,0); msleep(100);
    drive(FRONT_PWR, FRONT_PWR); msleep(FRONT_MS);
}

static void turnRight180(void) {
    drive(0,0);
    int BACK_MS = 1500, BACK_PWR = 60;
    drive(-BACK_PWR, -BACK_PWR); msleep(BACK_MS);

    drive(0,0); msleep(100);
    int SPIN = 80;
    drive(+SPIN, -SPIN); msleep(1400);
}

// ====== *** NUR DIESE ZWEI METHODEN WURDEN "mit Leben gefüllt" *** ======
static inline void signal_i_am_here(void) {
    if (!comm_connected) return; // failsafe
    const char *msg = "HERE\n";
    ssize_t s = send(comm_fd, msg, (int)strlen(msg), 0);
    (void)s; // Ignorieren – wir pollen auf Empfangsseite
}

static inline int partner_has_arrived(void) {
    if (!comm_connected) return 0;

    if (partner_here_flag) return 1; // bereits empfangen

    char buf[COMM_BUF_SZ];
    // nicht-blockierend lesen
    for(;;){
        ssize_t n = recv(comm_fd, buf, sizeof(buf)-1, MSG_DONTWAIT);
        if (n > 0){
            buf[n] = '\0';
            // einfache Protokollierung: irgendein "HERE" im Puffer reicht
            if (strstr(buf, "HERE") != NULL){
                partner_here_flag = 1;
                return 1;
            }
            // sonst weiter versuchen, falls mehr im Socket steckt
            continue;
        } else if (n == 0){
            // Verbindung wurde geschlossen -> als nicht da behandeln
            comm_close();
            return 0;
        } else {
            if (errno == EAGAIN || errno == EWOULDBLOCK){
                // nichts verfügbar – später wieder prüfen
                return 0;
            } else {
                // echter Fehler -> Verbindung schließen
                comm_close();
                return 0;
            }
        }
    }
}

// ====== Staging-Protokoll (unverändert) ======
static void staging_wait_protocol(void) {
    drive(0,0);
    signal_i_am_here();
    msleep(150); // Stabilisierung

    while (!partner_has_arrived()) {
        msleep(20);
    }

    if (PRIORITY_ROLE == 0) {
        msleep(WAIT_AFTER_FIRST_MS);
    }
}

// ====== Linienfolger mit 8er-Logik & alternierendem Staging (unverändert) ======
void followLine(int duration_ms) {
    int elapsed = 0;
    int currentCorner = 0;      // 0..7, danach Reset
    int staged_this_cycle = 0;  // pro 8er-Zyklus max. einmal stagen
    static int next_wait_corner = WAIT_CORNER_A; // alterniert zwischen A und B

    while (elapsed < duration_ms) {
        int L = analog(LEFT_SENSOR_PORT);
        int R = analog(RIGHT_SENSOR_PORT);

        int L_black = is_black(L);
        int R_black = is_black(R - 100);

        if (!L_black && !R_black) {
            drive(FAST_FWD, FAST_FWD);

        } else if (L_black && !R_black) {
            drive(HARD_TURN_BACK, +HARD_TURN);

        } else if (R_black && !L_black) {
            drive(+HARD_TURN, HARD_TURN_BACK);

        } else {
            // beide schwarz -> Ecke erkannt
            drive(0,0);

            // Alternierendes Staging an 3 bzw. 7
            if (!staged_this_cycle && currentCorner == next_wait_corner) {
                // Reset des Flags für diesen Treffpunkt
                partner_here_flag = 0;
                staging_wait_protocol();
                staged_this_cycle = 1;
                next_wait_corner = (next_wait_corner == WAIT_CORNER_A) ? WAIT_CORNER_B : WAIT_CORNER_A;
            }

            // Kurve fahren (erste 4: links, zweite 4: rechts)
            if (currentCorner < 4) {
                turnLeft90();
                currentCorner++;
            } else {
                turnRight90();
                currentCorner++;
            }

            if (currentCorner == 8) {
                currentCorner = 0;
                staged_this_cycle = 0;
            }

            drive(0,0); msleep(30);
            drive(FAST_FWD, FAST_FWD);
        }

        msleep(DT_MS);
        elapsed += DT_MS;
    }
    ao();
}

int main(void) {
    setvbuf(stdout, NULL, _IONBF, 0);
    printf("2-sensor line follower with alternating staging (TCP sync)...\n");

    if (!comm_init()){
        printf("WARN: comm_init() failed – fahre ohne Sync weiter.\n");
    }

    followLine(500000); // ~500s

    comm_close();
    msleep(200);
    ao();
    return 0;
}
